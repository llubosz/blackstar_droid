<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.App.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/reverb_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header row: title + power -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/textView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="REVERB"
                android:textColor="@color/reverb_accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <View
                android:id="@+id/reverb_power_led"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/led_off" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reverb_power_switch"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@drawable/contactless_payment"
                app:iconSize="20dp" />

        </LinearLayout>

        <!-- Type dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/reverb_type_layout"
            style="@style/Widget.App.ExposedDropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="Type">

            <AutoCompleteTextView
                android:id="@+id/reverb_type_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/colorOnSurface" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Size slider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIZE"
            android:textColor="@color/colorOnSurfaceDim"
            android:textSize="12sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/reverb_size_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1" />

        <!-- Level slider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL"
            android:textColor="@color/colorOnSurfaceDim"
            android:textSize="12sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/reverb_level_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
